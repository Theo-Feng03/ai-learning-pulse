# === 必填 ===
# SQLite 数据库文件（相对 prisma/ 目录）
DATABASE_URL="file:./dev.db"

# === 模型配置（可选：全部留空时进入 no_ai 模式，采集/手工记录/发布/导出仍可用） ===
# OpenAI-compatible Chat Completions 接口地址，例如：
#   https://api.openai.com/v1
#   http://localhost:11434/v1   （Ollama）
MODEL_BASE_URL=""
# API Key（Ollama 等本地服务可留空）
MODEL_API_KEY=""
# 模型名称，例如 gpt-4o-mini / qwen2.5:7b
MODEL_NAME=""
# 单次请求超时（毫秒），默认 30000
MODEL_TIMEOUT_MS="30000"
# 模型调用失败重试次数，默认 1
MODEL_MAX_RETRIES="1"

# === 采集与 AI 行为（可选） ===
# 单信源抓取超时（毫秒），默认 15000
FETCH_TIMEOUT_MS="15000"
# 信源抓取并发，默认 5
INGEST_CONCURRENCY="5"
# AI 分析并发，默认 2
AI_CONCURRENCY="2"
# 单次运行最大 AI 处理条数，默认 30
AI_MAX_PER_RUN="30"
# 标题相似度聚合阈值（0-1），默认 0.85
TITLE_SIMILARITY_THRESHOLD="0.85"

# === 导出（可选） ===
# showcase.json 输出目录，默认 exports
EXPORT_DIR="exports"

# 公开导出中显示的 GitHub 仓库链接（可选）
SHOWCASE_GITHUB_URL=""

# === 双机同步（可选） ===
# 私有 GitHub 仓库（owner/repo），存放数据快照。留空则同步功能关闭。
# 首次使用：填好后执行 pnpm sync:init；另一台电脑配置相同值后 pnpm sync:pull
SYNC_REPO=""
